# 驴酱杯赛事后端 - 环境变量模板
# 使用说明：
# 1. 复制此文件为对应环境的配置文件：
#    - 开发环境: cp .env.example .env.development
#    - 生产环境: cp .env.example .env.production
#    - 测试环境: cp .env.example .env.test
# 2. 根据环境修改配置值
# 3. 运行时会自动加载对应的 .env 文件
#
# 注意：所有变量都是必需的，缺少任何一个都会导致服务启动失败！

# ==========================================
# 服务器配置
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# JWT 配置
# ==========================================
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# ==========================================
# 管理员账号
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ==========================================
# 数据库配置
# ==========================================
# 开发环境: ./data/lvjiang-dev.db
# 测试环境: :memory: (内存数据库)
# 生产环境: ./data/lvjiang.db
DATABASE_PATH=./data/lvjiang.db

# ==========================================
# CORS 配置
# ==========================================
# 开发环境: * (允许所有来源)
# 生产环境: 限制为特定域名，如 https://your-domain.com
CORS_ORIGIN=*

# ==========================================
# 上传配置
# ==========================================
# 上传文件存放目录
# 开发环境: ./uploads (相对于项目根目录)
# 生产环境: /app/uploads (容器内绝对路径，Docker 会挂载宿主机目录)
UPLOAD_BASE_DIR=./uploads

# ==========================================
# 安全配置
# ==========================================
# 是否启用 Swagger API 文档
# 默认: false (关闭)
# 开发环境: true
# 生产环境: false (不设置或设为 false)
ENABLE_SWAGGER=true

# ==========================================
# 日志配置
# ==========================================
# 日志级别控制
# 可选值：debug（详细）、log（普通）、warn（警告）、error（错误）
# 开发环境建议：debug（显示所有日志包括 debug）
# 生产环境建议：warn 或 error（不显示 debug 日志）
# 生产环境使用 LOG_LEVEL=warn 将只显示 warn、error 和 log 级别的日志
LOG_LEVEL=debug
